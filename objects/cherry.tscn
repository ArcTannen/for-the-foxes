[sub_resource type="GDScript" id="GDScript_pdxjc"]
script/source = "extends Area2D


func _on_body_entered(body):
	if body.name == \"Player\":
		Game.playerHP += 2
		if Game.playerHP > 10:
			Game.playerHP = 10
		Game.playerGP += 5
		
		var tw_lift = get_tree().create_tween()
		var tw_fade = get_tree().create_tween()
		tw_lift.tween_property(self, \"position\", position - Vector2(0, 25), 0.2)
		tw_fade.tween_property(self, \"modulate:a\", 0, 0.2)
		tw_fade.tween_callback(queue_free)
"

